 147:Core/Src/freertos.c **** void StartBtn_Task(void *argument)
 148:Core/Src/freertos.c **** {
 149:Core/Src/freertos.c ****   /* USER CODE BEGIN StartBtn_Task */
 150:Core/Src/freertos.c **** 
 151:Core/Src/freertos.c ****   /* Infinite loop */
 152:Core/Src/freertos.c ****   for(;;)
 153:Core/Src/freertos.c ****   {
 154:Core/Src/freertos.c ****     if (HAL_GPIO_ReadPin(GPIOB, GPIO_PIN_9) == GPIO_PIN_RESET) 
 155:Core/Src/freertos.c ****     {
 156:Core/Src/freertos.c ****       osDelay(10); // 防抖延时
 157:Core/Src/freertos.c ****       if (HAL_GPIO_ReadPin(GPIOB, GPIO_PIN_9) == GPIO_PIN_RESET)
 158:Core/Src/freertos.c ****       {
 159:Core/Src/freertos.c ****         btn_counter++;
 160:Core/Src/freertos.c ****         osMessageQueuePut(Btn_QueueHandle, &btn_counter, NULL, osWaitForever);
 161:Core/Src/freertos.c ****       }
 162:Core/Src/freertos.c ****       while (HAL_GPIO_ReadPin(GPIOB, GPIO_PIN_9) == GPIO_PIN_RESET)
 163:Core/Src/freertos.c ****       {
 164:Core/Src/freertos.c ****         osDelay(10); // 等待按键释放
 165:Core/Src/freertos.c ****       }
 166:Core/Src/freertos.c ****     }
 167:Core/Src/freertos.c ****     else
 168:Core/Src/freertos.c ****     {
 169:Core/Src/freertos.c ****       osDelay(10);
 170:Core/Src/freertos.c ****     }
 171:Core/Src/freertos.c ****   }
 172:Core/Src/freertos.c ****   /* USER CODE END StartBtn_Task */
 173:Core/Src/freertos.c **** }
