 156:Core/Src/freertos.c **** void StartBtn_Task(void *argument)
 157:Core/Src/freertos.c **** {
 158:Core/Src/freertos.c ****   /* USER CODE BEGIN StartBtn_Task */
 159:Core/Src/freertos.c **** 
 160:Core/Src/freertos.c ****   /* Infinite loop */
 161:Core/Src/freertos.c ****   for(;;)
 162:Core/Src/freertos.c ****   {
 163:Core/Src/freertos.c ****     if (HAL_GPIO_ReadPin(GPIOB, GPIO_PIN_9) == GPIO_PIN_RESET) 
 164:Core/Src/freertos.c ****     {
 165:Core/Src/freertos.c ****       osDelay(10); // 防抖延时
 166:Core/Src/freertos.c ****       if (HAL_GPIO_ReadPin(GPIOB, GPIO_PIN_9) == GPIO_PIN_RESET)
 167:Core/Src/freertos.c ****       {
 168:Core/Src/freertos.c ****         btn1_counter++;
 169:Core/Src/freertos.c ****         osMessageQueuePut(Btn1_QueueHandle, &btn1_counter, NULL, osWaitForever);
 170:Core/Src/freertos.c ****       }
 171:Core/Src/freertos.c ****       while (HAL_GPIO_ReadPin(GPIOB, GPIO_PIN_9) == GPIO_PIN_RESET)
 172:Core/Src/freertos.c ****       {
 173:Core/Src/freertos.c ****         osDelay(10); // 等待按键释放
 174:Core/Src/freertos.c ****       }
 175:Core/Src/freertos.c ****     }
 176:Core/Src/freertos.c ****     else
 177:Core/Src/freertos.c ****     {
 178:Core/Src/freertos.c ****       osDelay(10);
 179:Core/Src/freertos.c ****     }
 180:Core/Src/freertos.c ****   }
 181:Core/Src/freertos.c ****   /* USER CODE END StartBtn_Task */
 182:Core/Src/freertos.c **** }
